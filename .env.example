# ============================================================
# Nazartepa 103 — Environment variables (example)
# Nusxa oling: cp .env.example .env  (yoki Windows: copy .env.example .env)
# ============================================================

# --- App ---
APP_NAME=Nazartepa 103
ENVIRONMENT=development            # development | production | test
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Security (JWT) ---
# Ishlab chiqarishda ALBATTA o'zgartiring! Yangi kalit:  openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-a-long-random-hex-string
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# --- Database (PostgreSQL) ---
POSTGRES_USER=nazartepa
POSTGRES_PASSWORD=nazartepa_dev_password
POSTGRES_DB=nazartepa103
POSTGRES_HOST=localhost            # docker-compose ichida: db
POSTGRES_PORT=5432
# Async URL (SQLAlchemy uchun). Docker'da host = db
DATABASE_URL=postgresql+asyncpg://nazartepa:nazartepa_dev_password@localhost:5432/nazartepa103

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- CORS (frontend manzillari, vergul bilan) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Rate limiting / brute-force ---
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# --- Seed admin (birinchi ishga tushirishda) ---
FIRST_SUPERADMIN_EMAIL=admin@nazartepa.uz
FIRST_SUPERADMIN_PASSWORD=Admin12345!

# --- AI Triage (Milestone 3) ---
# Provayder: rule_based | ollama | openai | anthropic
AI_TRIAGE_PROVIDER=rule_based
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
